PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learntrace?schema=public"
JWT_SECRET="learntrace_dev_secret_key_2024"
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# AI Features (Optional — Fill for AI-powered features)
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Cloudinary (Optional — Fill for cloud certificate storage, otherwise local disk is used)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# SMTP / Email Verification (Optional — Fill to send real verification emails)
# If not configured, verification links will be logged to the server console.
# For Gmail: Use smtp.gmail.com with port 587 and an App Password.
# To create a Gmail App Password:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Generate a new app password for "Mail"
#   3. Use that 16-character password below
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="LearnTrace <your_email@gmail.com>"
